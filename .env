# DB (nếu dùng)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=onus
DB_PASSWORD=secret
DB_NAME=onusdb


# Keyring (tuỳ chọn)
ONUSLIBS_PROFILE=default
