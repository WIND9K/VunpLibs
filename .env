# 1) API & paging
ONUSLIBS_BASE_URL=https://wallet.vndc.io
ONUSLIBS_PAGE_SIZE=10000              # pageSize mặc định
ONUSLIBS_TIMEOUT_S=60

# 2) Phân đoạn theo thời gian
ONUSLIBS_MAX_WINDOW_DAYS=1           # số ngày tối đa / window (ví dụ: 1, 3, 7)

# 3) Phân đoạn theo số record (trọng tâm hybrid)
ONUSLIBS_MAX_ROWS_PER_WINDOW=8000    # trần an toàn < 10k (giới hạn API)

# 4) Fallback auto-segment khi vẫn gặp 422
ONUSLIBS_MAX_SEGMENT_SPLIT_DEPTH=4   # số lần chia đôi tối đa khi 422
ONUSLIBS_AUTO_SEGMENT=true           # bật 422-split fallback

# 5) Song song
ONUSLIBS_PARALLEL=true               # song song theo page trong 1 window
ONUSLIBS_SEGMENT_PARALLEL=true       # song song theo segment
ONUSLIBS_SEGMENT_MAX_WORKERS=4       # số segment tối đa chạy song song
