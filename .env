# =============================================================================
# ONUSLIBS CONFIGURATION (v3)
# =============================================================================
# File cấu hình cho thư viện OnusLibs.
# Các biến này sẽ được load tự động nếu có python-dotenv.
# Thứ tự ưu tiên: ENV hệ thống > .env file > Giá trị mặc định trong code.

# -----------------------------------------------------------------------------
# 1. API & HTTP CLIENT
# -----------------------------------------------------------------------------
# Base URL của API Cyclos/ONUS (BẮT BUỘC)
ONUSLIBS_BASE_URL=https://wallet.vndc.io

# Số lượng record tối đa mỗi trang (pageSize) gửi lên API.
# Mặc định: 10000 (thường là giới hạn cứng của backend cho 1 page)
ONUSLIBS_PAGE_SIZE=10000

# Timeout cho mỗi request HTTP (giây).
# Mặc định: 60s. Tăng lên nếu mạng chậm hoặc query nặng.
ONUSLIBS_TIMEOUT_S=60

# Giới hạn số request/giây (Rate Limit) để tránh bị block IP.
# Mặc định: None (không giới hạn). Ví dụ: 5.0
# ONUSLIBS_REQ_PER_SEC=5.0

# Số lượng request song song tối đa (Max Inflight).
# Dùng cho cả phân trang song song và segment song song.
# Mặc định: 4
ONUSLIBS_MAX_INFLIGHT=4

# Bật/tắt HTTP/2 (yêu cầu cài đặt package 'h2').
# Mặc định: false (dùng HTTP/1.1 cho ổn định nếu server kén).
# ONUSLIBS_HTTP2=false

# Proxy server (nếu cần). Ví dụ: http://user:pass@host:port
# ONUSLIBS_PROXY=

# Xác thực SSL. Mặc định: true. Set false nếu dùng proxy MITM (không khuyến khích).
# ONUSLIBS_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# 2. HYBRID AUTO-SEGMENT (QUAN TRỌNG)
# -----------------------------------------------------------------------------
# Chiến thuật chia nhỏ datePeriod để vượt qua giới hạn 10k record của backend.

# Tầng 1: Chia datePeriod lớn thành các cửa sổ ngày nhỏ hơn.
# Ví dụ: 1 -> mỗi request tối đa 1 ngày. 0 -> không chia theo ngày.
ONUSLIBS_MAX_WINDOW_DAYS=2

# Tầng 2: Chia nhỏ tiếp cửa sổ ngày dựa trên số lượng record ước tính (Peek).
# Nếu X-Total-Count > giá trị này, thư viện sẽ tự chia nhỏ window thành nhiều segment.
# Giá trị nên < 10000 để an toàn.
ONUSLIBS_MAX_ROWS_PER_WINDOW=8000

# Tầng 3: Fallback khi gặp lỗi 422 (Pagination Error).
# Nếu request vẫn lỗi dù đã chia nhỏ, tự động chia đôi thời gian và thử lại (đệ quy).
# Mặc định: true
ONUSLIBS_AUTO_SEGMENT=true

# Độ sâu tối đa cho việc chia đôi đệ quy khi fallback (Tầng 3).
# Ví dụ: 4 -> chia tối đa 2^4 = 16 phần nhỏ nữa.
ONUSLIBS_MAX_SEGMENT_SPLIT_DEPTH=4

# -----------------------------------------------------------------------------
# 3. PARALLEL PROCESSING (XỬ LÝ SONG SONG)
# -----------------------------------------------------------------------------
# Bật song song khi fetch các trang (pages) trong cùng 1 segment.
# Mặc định: true
ONUSLIBS_PARALLEL=true

# Bật song song khi fetch các segment thời gian khác nhau.
# Mặc định: true
ONUSLIBS_SEGMENT_PARALLEL=true

# Số worker tối đa cho segment parallel.
# Nếu không set, sẽ dùng giá trị của ONUSLIBS_MAX_INFLIGHT.
ONUSLIBS_SEGMENT_MAX_WORKERS=4

# -----------------------------------------------------------------------------
# 4. SECURITY & AUTHENTICATION
# -----------------------------------------------------------------------------
# Backend lưu trữ secret: 'keyring' (an toàn, local) hoặc 'env' (server/docker).
# Mặc định: keyring (nếu có), fallback sang env.
ONUSLIBS_SECRETS_BACKEND=keyring

# Tên service trong Keyring.
ONUSLIBS_KEYRING_SERVICE=OnusLibs

# Tên item (key) chứa token trong Keyring.
ONUSLIBS_KEYRING_ITEM=ACCESS_CLIENT_TOKEN

# Cho phép đọc token từ ENV nếu không tìm thấy trong Keyring.
# Mặc định: true
ONUSLIBS_FALLBACK_ENV=true

# Tên header dùng để gửi token.
# Mặc định: Access-Client-Token
ONUSLIBS_TOKEN_HEADER=Access-Client-Token

# -----------------------------------------------------------------------------
# 5. DATABASE (OPTIONAL)
# -----------------------------------------------------------------------------
# Cấu hình kết nối DB (nếu dùng module onuslibs.db).
# Có thể lưu trong Keyring để bảo mật hơn.
# ONUSLIBS_DB_HOST=127.0.0.1
# ONUSLIBS_DB_PORT=3306
# ONUSLIBS_DB_USER=root
# ONUSLIBS_DB_PASSWORD=secret
# ONUSLIBS_DB_NAME=onus_data
# ONUSLIBS_DB_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# 6. LOGGING & DEBUG
# -----------------------------------------------------------------------------
# Mức độ log: DEBUG, INFO, WARNING, ERROR.
# Mặc định: INFO
ONUSLIBS_LOG_LEVEL=INFO

# Tự động load file .env này khi import thư viện.
# Mặc định: true
ONUSLIBS_AUTO_DOTENV=true
