# ==============================================================================
# OnusLibs Configuration Template - Module DB v3.1
# Sao chép nội dung này vào file .env của bạn
# ==============================================================================

# ==============================================================================
# 1. HTTP & API Configuration (REQUIRED)
# ==============================================================================

ONUSLIBS_BASE_URL=https://wallet.vndc.io
ONUSLIBS_PAGE_SIZE=2000
ONUSLIBS_REQ_PER_SEC=2
ONUSLIBS_MAX_INFLIGHT=4
ONUSLIBS_TIMEOUT_S=60
ONUSLIBS_HTTP2=true
ONUSLIBS_VERIFY_SSL=true
ONUSLIBS_PROXY=

# ==============================================================================
# 2. Hybrid Auto-Segment Configuration
# ==============================================================================

ONUSLIBS_PARALLEL=true
ONUSLIBS_MAX_WINDOW_DAYS=1
ONUSLIBS_MAX_ROWS_PER_WINDOW=8000
ONUSLIBS_AUTO_SEGMENT=true
ONUSLIBS_MAX_SEGMENT_SPLIT_DEPTH=4
ONUSLIBS_SEGMENT_PARALLEL=true
ONUSLIBS_SEGMENT_MAX_WORKERS=4

# ==============================================================================
# 3. Security & Authentication
# ==============================================================================

ONUSLIBS_SECRETS_BACKEND=keyring
ONUSLIBS_KEYRING_SERVICE=OnusLibs
ONUSLIBS_KEYRING_ITEM=ACCESS_CLIENT_TOKEN
ONUSLIBS_FALLBACK_ENV=true
ONUSLIBS_TOKEN_HEADER=Access-Client-Token

# ==============================================================================
# 4. DATABASE Configuration (v3.1 - ĐÃ CẬP NHẬT)
# ==============================================================================

# ----- Connection Settings -----
ONUSLIBS_DB_HOST=127.0.0.1
ONUSLIBS_DB_PORT=3306
ONUSLIBS_DB_USER=onusreport
ONUSLIBS_DB_PASSWORD=your_password_here
ONUSLIBS_DB_NAME=onusreport
ONUSLIBS_DB_CONNECT_TIMEOUT=10
ONUSLIBS_DB_SSL_CA=

# ----- ⚡ Connection Pool Settings (MỚI v3.1) -----
ONUSLIBS_DB_POOL_SIZE=5
ONUSLIBS_DB_MAX_OVERFLOW=10
ONUSLIBS_DB_RETRY_COUNT=3

# ==============================================================================
# 5. Logging
# ==============================================================================

ONUSLIBS_LOG_LEVEL=INFO
ONUSLIBS_AUTO_DOTENV=true

