# ------------------------------
# OS / Editor cruft
# ------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig
*.tmp
*.bak
.idea/
.vscode/

# ------------------------------
# Python bytecode & caches
# ------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ------------------------------
# Virtual environments / pyenv / direnv
# ------------------------------
.venv/
venv/
ENV/
env/
.python-version
.envrc

# ------------------------------
# Packaging / build artifacts
# ------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl
.pex/

# ------------------------------
# Test / Coverage
# ------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml

# ------------------------------
# Lint / Type check caches
# ------------------------------
.mypy_cache/
.dmypy.json
.pytype/
.pyre/
.pyright/
ruff_cache/

# ------------------------------
# Notebooks
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# Logs & local runtime files
# ------------------------------
logs/
*.log

# ------------------------------
# Local env & secrets
# ------------------------------
# .env
.env.*
!.env.example

# ------------------------------
# Project-specific (OnusLibs)
# ------------------------------
# Example outputs (keep scripts, ignore generated data)
examples/*.csv
examples/*.json
examples/output/
# Tools output (keep sources)
tools/*.csv
tools/*.json
# Temporary & scratch
tmp/
temp/
files/

# ------------------------------
# Misc
# ------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
